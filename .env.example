## GridCool (local dev)
DEMO_MODE=true

## Backend
# MongoDB Atlas or local Mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=gridcool

# OpenWeatherMap (Phase 4, optional in demo mode)
OPENWEATHER_API_KEY=

# ML load forecast (Phase 2 foundation; optional)
USE_ML_FORECAST=false
ML_ARTIFACT_DIR=artifacts/ml
ML_FORECAST_HORIZON_HOURS=12
ML_DATA_CSV=backend/data/chennai_hourly_load.csv
# Relative to backend root; `data/chennai_hourly_load.csv` is also accepted.
ML_FORECAST_REFRESH_MINUTES=15
AUTO_DISPATCH_ENABLED=true
AUTO_DISPATCH_COOLDOWN_MINUTES=120

## Frontend
# Used by frontend fetch + websocket URL inference
VITE_BACKEND_HTTP=http://localhost:8000

